{
  "name": "jose-grana2-dev",
  "version": "1.0.0",
  "description": "Portfolio personal estático — task05 (CSS/SASS).",
  "private": true,
  "scripts": {
    "sass": "sass assets/scss/main.scss assets/css/main.css --no-source-map --style=expanded",
    "sass:min": "sass assets/scss/main.scss assets/css/main.css --no-source-map --style=compressed",
    "sass:watch": "sass --watch assets/scss/main.scss:assets/css/main.css --no-source-map --style=expanded",
    "build": "npm run sass:min"
  },
  "devDependencies": {
    "sass": "^1.77.0"
  }
}
